# ── Copier ce fichier en .env et remplir les valeurs ──

# Base de données
# SQLite (développement local)
DATABASE_URL=sqlite:///datapulse.db

# PostgreSQL (production — Railway / Render / VPS)
# DATABASE_URL=postgresql://user:password@host:5432/datapulse

# Sécurité — OBLIGATOIRE en production
# Générer avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-use-secrets-token-hex

# Rate limiting (optionnel — Redis pour prod multi-worker)
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# Upload
MAX_UPLOAD_MB=16

# ── Email / SMTP (pour la vérification d'e-mail) ──
# Gmail: activez « Mots de passe d'application » (2FA requis)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASS=votre_mot_de_passe_application
SMTP_FROM=DataPulse <votre@gmail.com>
# Si SMTP_HOST est vide, le code est affiché dans la console (mode dev).
